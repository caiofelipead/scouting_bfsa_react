# ============================================================
# Scouting BFSA — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# All variables without defaults are REQUIRED.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (required for production)
# For local dev you can use SQLite by leaving this empty
DATABASE_URL=postgresql://user:password@host:5432/scouting_db

# ── Authentication ────────────────────────────────────────────
# JWT signing key — REQUIRED, app will not start without it
JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# Token expiration in minutes (default: 480 = 8 hours)
TOKEN_EXPIRE_MINUTES=480

# Initial admin account (created on first startup if set)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NAME=Administrador

# SQLite fallback path for auth DB (only used if DATABASE_URL is empty)
# AUTH_DB_PATH=./users.db

# ── Google Sheets ─────────────────────────────────────────────
# Sheet ID for data sync (has a default, but set your own)
# GOOGLE_SHEET_ID=your-google-sheet-id

# Service Account JSON key for private spreadsheet access.
# Paste the full JSON content or its base64-encoded version.
# Without this, the app falls back to public CSV export (sheet must be published).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://botafogo-sp.vercel.app,https://scouting-bfsa-react.onrender.com,http://localhost:5173
